---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'GW2 Homestead Catalog' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Guild Wars 2 Homestead decoration catalog" />
    <link rel="icon" type="image/png" href={new URL('../assets/homestead.png', import.meta.url).href} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.json`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
