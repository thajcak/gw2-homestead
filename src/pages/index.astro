---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import IconGrid from '../components/IconGrid.astro';
import ChangeLogPanel from '../components/ChangeLogPanel.astro';
import FilterPrompt from '../components/FilterPrompt.astro';
import type { CatalogData } from '../scripts/catalog';
import { buildChangelogDays } from '../utils/buildChangelogDays';

const decorationEntries = await getCollection('decorations');
const categoryEntries = await getCollection('categories');

const allDecorations = decorationEntries
  .map((entry) => entry.data)
  .sort((a, b) => a.name.localeCompare(b.name));

const decorations = allDecorations.filter((decoration) => !decoration.removed);

const categories = categoryEntries
  .map((entry) => entry.data)
  .sort((a, b) => a.name.localeCompare(b.name));

const changelogDays = buildChangelogDays(allDecorations, categories);

const catalogData: CatalogData = {
  searchIndex: decorations.map((decoration) => ({
    id: decoration.id,
    name: decoration.name,
    description: decoration.description,
    categories: decoration.categories,
  })),
  decorations: Object.fromEntries(
    allDecorations.map((decoration) => {
      const { history: _history, ...catalogDecoration } = decoration;
      return [String(decoration.id), catalogDecoration];
    })
  ),
  categories,
  changelogDays,
};
---

<BaseLayout>
  <div class="min-h-screen bg-gray-100">
    <Header categories={categories.filter((category) => !category.removed)} />

    <main class="container mx-auto px-6">
      <IconGrid decorations={decorations} />
      <div id="empty-state" class="hidden py-10 text-center text-sm text-gray-600">
        No decorations found.
      </div>
    </main>

    <ChangeLogPanel days={changelogDays} />
    <FilterPrompt />
  </div>

  <script id="catalog-data" type="application/json" set:html={JSON.stringify(catalogData)}></script>
  <script>
    import { initCatalog } from '../scripts/catalog';

    const dataElement = document.getElementById('catalog-data');
    if (dataElement?.textContent) {
      initCatalog(JSON.parse(dataElement.textContent), import.meta.env.BASE_URL);
    }
  </script>
</BaseLayout>
