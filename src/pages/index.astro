---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import IconGrid from '../components/IconGrid.astro';
import ChangeLogPanel from '../components/ChangeLogPanel.astro';
import FilterPrompt from '../components/FilterPrompt.astro';
import { assetUrl } from '../utils/assetUrl';

const categoryEntries = await getCollection('categories');

const categories = categoryEntries
  .map((entry) => entry.data)
  .sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout preloadCatalogIndex={assetUrl('catalog/search-index.json')}>
  <div class="site">
    <Header categories={categories.filter((category) => !category.removed)} />

    <main class="main">
      <IconGrid />
      <div id="empty-state" class="empty-state is-hidden">No decorations found.</div>
    </main>

    <ChangeLogPanel />
    <FilterPrompt />
  </div>

  <script>
    import { initCatalog } from '../scripts/catalog';

    initCatalog(import.meta.env.BASE_URL).catch((error) => {
      console.error('Failed to initialize catalog', error);
    });
  </script>
</BaseLayout>
