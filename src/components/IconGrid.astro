---
import type { Decoration } from '../types';
import { assetUrl } from '../utils/assetUrl';

interface Props {
  decorations: Decoration[];
}

const { decorations } = Astro.props;
---

<div class="container mx-auto px-4 md:px-8 lg:px-16 py-8">
  <div id="icon-grid" class="grid-layout">
    {
      decorations.map((decoration) => (
        <div
          class="catalog-item relative w-74 h-74 cursor-pointer rounded-lg hover:ring-2 hover:ring-blue-400 hover:ring-offset-1"
          data-id={decoration.id}
          data-categories={decoration.categories.join(',')}
          data-search-text={`${decoration.name} ${decoration.description ?? ''}`.toLowerCase()}
        >
          <div class="image-frame image-frame--icon is-loading" data-image-state="loading">
            <div class="image-frame__skeleton" aria-hidden="true"></div>
            <img
              class="image-frame__img"
              src={assetUrl(decoration.icon)}
              alt={decoration.name}
              width={74}
              height={74}
              loading="lazy"
              decoding="async"
            />
            <div class="image-frame__fallback" aria-hidden="true">?</div>
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  import { wireImageFrames } from '../scripts/imageLoading';

  const grid = document.getElementById('icon-grid');
  if (grid) {
    wireImageFrames(grid);
  }
</script>
