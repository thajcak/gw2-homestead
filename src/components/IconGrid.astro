---
import type { Decoration } from '../types';
import { assetUrl } from '../utils/assetUrl';

interface Props {
  decorations: Decoration[];
}

const { decorations } = Astro.props;
const placeholderPreview = assetUrl('images/placeholder.png');
---

<div class="container mx-auto px-4 md:px-8 lg:px-16 py-8">
  <div id="icon-grid" class="grid-layout">
    {
      decorations.map((decoration) => (
        <div
          class="catalog-item relative w-74 h-74 cursor-pointer transition-transform hover:scale-105"
          data-id={decoration.id}
          data-categories={decoration.categories.join(',')}
          data-search-text={`${decoration.name} ${decoration.description ?? ''}`.toLowerCase()}
        >
          <img
            src={assetUrl(decoration.icon)}
            alt={decoration.name}
            width={74}
            height={74}
            class="w-full h-full object-cover border-2 border-gray-300 rounded-lg"
            loading="lazy"
          />
        </div>
      ))
    }
  </div>
</div>

<script define:vars={{ placeholderPreview }}>
  window.__catalogPlaceholderPreview = placeholderPreview;
</script>
