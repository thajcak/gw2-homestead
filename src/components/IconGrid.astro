---
import type { ImageMetadata } from 'astro';
import type { Decoration } from '../types';
import CatalogIcon from './CatalogIcon.astro';

interface Props {
  decorations: Decoration[];
}

const { decorations } = Astro.props;

const iconModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/decorations/*/icon.png',
  { eager: true }
);

const iconsById = new Map<number, ImageMetadata>();
for (const [path, module] of Object.entries(iconModules)) {
  const match = path.match(/decorations\/(\d+)\/icon\.png$/);
  if (match) {
    iconsById.set(Number(match[1]), module.default);
  }
}
---

<div class="container mx-auto px-4 md:px-8 lg:px-16 py-8">
  <div id="icon-grid" class="grid-layout">
    {
      decorations.map((decoration) => (
        <CatalogIcon decoration={decoration} icon={iconsById.get(decoration.id)} />
      ))
    }
  </div>
</div>
