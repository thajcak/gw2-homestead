<div id="filter-prompt" class="is-hidden fixed bottom-4 right-4 z-[220] bg-white border border-gray-200 shadow-xl rounded-lg p-4 w-[min(90vw,420px)]">
  <p class="text-sm text-gray-800">
    <span id="filter-prompt-name" class="font-semibold"></span> is currently hidden by Search or Category filters.
    Remove filters to make it visible?
  </p>
  <div class="mt-3 flex justify-end gap-2">
    <button
      id="filter-prompt-no"
      type="button"
      class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50"
    >
      No
    </button>
    <button
      id="filter-prompt-yes"
      type="button"
      class="px-3 py-1.5 text-sm bg-gray-900 text-white rounded hover:bg-black"
    >
      Yes
    </button>
  </div>
</div>
