---
import type { Category } from '../types';
import homesteadIcon from '../assets/homestead.png';

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<header class="header">
  <div class="container header__inner">
    <div class="header__spacer" aria-hidden="true"></div>

    <div class="header__controls">
      <select id="category-select" class="header__select">
        <option value="all">All Categories</option>
        {
          categories.map((category) => (
            <option value={category.id} data-category-count data-category-name={category.name}>
              {category.name}
            </option>
          ))
        }
      </select>

      <div class="header__actions">
        <button id="home-reset" type="button" class="header__home" aria-label="Reset filters and scroll to top">
          <img src={homesteadIcon.src} alt="Homestead" width="32" height="32" />
        </button>
        <button id="open-changelog" type="button" class="header__changelog" aria-label="View updates">
          ?
        </button>
      </div>

      <div class="header__search-wrap">
        <input
          id="search-input"
          type="text"
          class="header__search"
          placeholder="Search decorations..."
        />
        <button
          id="clear-search"
          type="button"
          class="header__clear-search is-hidden"
          aria-label="Clear search"
        >
          ×
        </button>
      </div>
    </div>

    <div class="header__spacer" aria-hidden="true"></div>
  </div>
</header>
